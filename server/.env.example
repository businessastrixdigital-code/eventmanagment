# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=replace_this_with_a_long_random_string
SESSION_SECRET=replace_this_with_a_long_random_string

# Database — a free Postgres instance (Neon or Supabase). Do NOT use local SQLite;
# free hosting platforms wipe the local filesystem on redeploy/sleep, which would
# silently delete all data.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudinary — free tier. Used for all photo uploads (couple cover photos, event
# cover images, gallery photos). Local disk storage is not used for the same
# ephemeral-filesystem reason as above.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
